%% F6 — Process As-Is (Repo-afledt)
%% Viser: Nuværende bud-til-fakturering flow UDEN AI-støtte
%% Kilde: docs/flows/FLOW_BIDDING.md, FLOW_CONTRACT_SIGNING.md
flowchart TB
    Start(["Freelancer<br/>søger job"])
    Bid["Freelancer<br/>afgiver bud"]
    AdminManual{"Admin<br/>gennemgang<br/><i>Erfaringsbaseret</i>"}
    Negotiate["Forhandling"]
    GenContract["Kontrakt<br/>genereres"]
    Sign["Dual-signature<br/><i>Admin + Freelancer</i>"]
    Active["Kontrakt aktiv"]
    Time["Tidsregistrering"]
    Payment["Fakturering<br/><i>via E-conomic</i>"]

    Start --> Bid
    Bid --> AdminManual
    AdminManual -->|"Godkendt"| GenContract
    AdminManual -->|"Modforslag"| Negotiate
    Negotiate --> AdminManual
    GenContract --> Sign --> Active --> Time --> Payment

    %% ── LEGEND ──
    subgraph Legend[" "]
        direction LR
        LS(["◻ Start / slutpunkt"])
        LStep["◻ Procestrin"]
        LDec{"◇ Menneskelig beslutning"}
        LA["── Sekvensielt flow"]
    end

    %% ── STYLES ──
    style Start fill:#ffffff,stroke:#1565c0,stroke-width:2px
    style Bid fill:#e3f2fd,stroke:#1565c0
    style AdminManual fill:#fff3e0,stroke:#e65100,stroke-width:3px
    style Negotiate fill:#fff3e0,stroke:#e65100
    style GenContract fill:#e8f5e9,stroke:#2e7d32
    style Sign fill:#e8f5e9,stroke:#2e7d32
    style Active fill:#e8f5e9,stroke:#2e7d32
    style Time fill:#f3e5f5,stroke:#6a1b9a
    style Payment fill:#f3e5f5,stroke:#6a1b9a
    style Legend fill:#fafafa,stroke:#bdbdbd,stroke-dasharray: 3
