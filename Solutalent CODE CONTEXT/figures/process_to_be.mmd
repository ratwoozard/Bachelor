%% F7 — Process To-Be (Repo-afledt)
%% Viser: Bud-til-fakturering flow MED AI-beslutningsstøtte
%% Kilde: supabase/functions/ai-match/, docs/flows/FLOW_BIDDING.md
%% REALITY LOCK: AI-matching trigges on-demand (freelancer+job), IKKE af bids.
%%   match_request.status = 'pending' ved oprettelse (ai-match/index.ts:866).
%%   Admin ændrer status via update_match_request_status() RPC.
flowchart TB
    Start(["Freelancer<br/>søger job"])
    Bid["Freelancer<br/>afgiver bud"]

    subgraph AISupport["AI-beslutningsstøtte<br/><i>(on-demand / admin-initieret)</i>"]
        AIMatch["Semantisk +<br/>regelbaseret<br/>matching"]
        AIExplain["Score +<br/>forklaring"]
        AIMatch --> AIExplain
    end

    ResultsDB[("Match-resultater<br/><i>status: pending</i>")]

    AdminReview{"Admin<br/>gennemgang<br/><i>Med AI-anbefaling</i>"}
    Negotiate["Forhandling"]
    GenContract["Kontrakt<br/>genereres"]
    Sign["Dual-signature<br/><i>Admin + Freelancer</i>"]
    Active["Kontrakt aktiv"]
    Time["Tidsregistrering"]
    Payment["Fakturering<br/><i>via E-conomic</i>"]

    Start --> Bid
    Bid -.->|"Kan trigge<br/>AI-match"| AISupport
    AISupport -->|"Persistér<br/>(status: pending)"| ResultsDB
    ResultsDB -.->|"Score +<br/>forklaring"| AdminReview
    AdminReview -->|"Godkendt"| GenContract
    AdminReview -->|"Modforslag"| Negotiate
    Negotiate --> AdminReview
    GenContract --> Sign --> Active --> Time --> Payment

    %% ── NOTE ──
    Note["ℹ️ AI-matching trigges<br/>on-demand eller af admin —<br/>IKKE automatisk ved bud"]
    Note -.-> AISupport

    %% ── LEGEND ──
    subgraph Legend[" "]
        direction LR
        LS(["◻ Start"])
        LStep["◻ Procestrin"]
        LAI["◻ AI-behandling"]
        LD[("◻ Datastore")]
        LDec{"◇ Menneskelig beslutning"}
        LA["── Dataflow"]
        LB["- - Kan trigge / støtte"]
    end

    %% ── STYLES ──
    style Start fill:#ffffff,stroke:#1565c0,stroke-width:2px
    style Bid fill:#e3f2fd,stroke:#1565c0
    style AISupport fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    style ResultsDB fill:#fce4ec,stroke:#c62828,stroke-width:2px
    style AdminReview fill:#fff3e0,stroke:#e65100,stroke-width:3px
    style Negotiate fill:#fff3e0,stroke:#e65100
    style GenContract fill:#f5f5f5,stroke:#757575
    style Sign fill:#f5f5f5,stroke:#757575
    style Active fill:#f5f5f5,stroke:#757575
    style Time fill:#f3e5f5,stroke:#6a1b9a
    style Payment fill:#f3e5f5,stroke:#6a1b9a
    style Note fill:#fffde7,stroke:#f57f17,stroke-dasharray: 5
    style Legend fill:#fafafa,stroke:#bdbdbd,stroke-dasharray: 3
    style LAI fill:#e8f5e9,stroke:#2e7d32
    style LD fill:#fce4ec,stroke:#c62828
    style LDec fill:#fff9c4,stroke:#f57f17
