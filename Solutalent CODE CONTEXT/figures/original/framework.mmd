%% Konceptuel figur — egen tilvirkning
%% Framework: Inputs → AI/DSS → beslutningsproces → outcomes

flowchart LR
    %% INPUTS
    subgraph Inputs["Inputs: data & kompetencer"]
        I1["Freelancer-profiler\n(CV, skills, erfaring)"]
        I2["Job-/projektdata\n(krav, kategori, lokation)"]
        I3["Historik & signaler\n(bids, kontrakter, feedback)"]
    end

    %% AI / DSS
    subgraph AI["AI/DSS — beslutningsstøtte"]
        A1["Embedding-baseret\nsemantisk matching"]
        A2["Regelbaseret scoring\n(kompetencer, erfaring, lokation)"]
        A3["Forklaringer &\nmatch-score"]
    end

    %% DECISION PROCESS
    subgraph Decision["Beslutningsproces (human-in-the-loop)"]
        D1["Admin review\n(match-kandidater)"]
        D2["Forhandling/bud\n(admin-medieret)"]
        D3["Kontraktbeslutning\n(dual-signature)"]
    end

    %% OUTCOMES
    subgraph Outcomes["Outcomes"]
        O1["Effektivitet\n(tidsforbrug, flow)"]
        O2["Kvalitet\n(match-kvalitet, beslutningskvalitet)"]
        O3["Compliance & ansvarlighed\n(GDPR, auditability)"]
    end

    %% CROSS-CUTTING CONSTRAINTS
    subgraph Governance["Governance & Transparens"]
        G1["Regler & adgang\n(platform governance)"]
        G2["Transparens\n(forklaringer, logning)"]
        G3["Etik/Fairness\n(Responsible AI)"]
    end

    Inputs --> AI --> Decision --> Outcomes

    G1 -.-> Decision
    G2 -.-> AI
    G2 -.-> Decision
    G3 -.-> AI
    G3 -.-> Decision

    style Inputs fill:#e3f2fd,stroke:#1565c0
    style AI fill:#e8f5e9,stroke:#2e7d32
    style Decision fill:#fff3e0,stroke:#e65100
    style Outcomes fill:#f3e5f5,stroke:#6a1b9a
    style Governance fill:#f5f5f5,stroke:#9e9e9e,stroke-dasharray: 5