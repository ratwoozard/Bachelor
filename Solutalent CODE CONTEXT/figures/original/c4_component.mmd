%% C4-lignende komponentdiagram (repo-deriveret, "light")
flowchart TB
    subgraph Frontend["Frontend (React)"]
        Pages["Pages\n(src/pages)"]
        Components["Components\n(src/components)"]
        Hooks["Hooks\n(src/hooks)"]
        Services["Services\n(src/services)"]
