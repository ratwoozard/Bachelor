    style Freelancer fill:#fff3e0,stroke:#e65100
    style Admin fill:#fff3e0,stroke:#e65100
    style Company fill:#fff3e0,stroke:#e65100
    style Legend fill:#fafafa,stroke:#bdbdbd,stroke-dasharray: 3
