%% F2 — Konceptuelt framework (Konceptuel figur — egen tilvirkning)
%% Viser: Inputs → AI/DSS → Beslutningsproces → Outcomes, med governance
%% Litteraturgrundlag: Hevner et al. (2004), Arnott & Pervan (2014), Jobin et al. (2019)
flowchart LR
    %% ── INPUTS ──
    subgraph Inputs["① Inputs"]
        I1["Freelancer-profiler<br/><i>CV, kompetencer, erfaring</i>"]
        I2["Job-/projektdata<br/><i>Krav, kategori, lokation</i>"]
        I3["Historik<br/><i>Bud, kontrakter, feedback</i>"]
    end

    %% ── AI/DSS ──
    subgraph AIDSS["② AI/DSS<br/>Beslutningsstøtte"]
        A1["Semantisk matching<br/><i>Embedding-similarity</i>"]
        A2["Regelbaseret scoring<br/><i>Kompetence, erfaring, lokation</i>"]
        A3["Match-forklaring<br/><i>Score + begrundelse</i>"]
    end

    %% ── HUMAN DECISION ──
    subgraph Decision["③ Beslutningsproces<br/><i>Human-in-the-loop</i>"]
        D1["Admin gennemgang"]
        D2["Bud & forhandling"]
        D3["Kontraktindgåelse<br/><i>Dual-signature</i>"]
    end

    %% ── OUTCOMES ──
    subgraph Outcomes["④ Outcomes"]
        O1["<b>Effektivitet</b><br/>• Time-to-match ¹ ³<br/>• Time-to-contract ¹ ³"]
        O2["<b>Kvalitet</b><br/>• Match-score fordeling ²<br/>• Godkendelsesrate ¹ ³"]
        O3["<b>Compliance</b><br/>• Audit-hændelser logget ¹ ³<br/>• RLS policy-dækning ²"]
    end

    %% ── GOVERNANCE ──
    subgraph Governance["Governance & Transparens"]
        G1["Platform-regler<br/><i>Roller, adgang</i>"]
        G2["Transparens<br/><i>Forklaringer, logning</i>"]
        G3["Ansvarlig AI<br/><i>Fairness, bias-bevidsthed</i>"]
    end

    %% ── MAIN FLOW ──
    Inputs --> AIDSS
    AIDSS -.->|"Beslutnings-<br/>støtte"| Decision
    Decision --> Outcomes

    %% ── GOVERNANCE CONSTRAINTS ──
    G1 -.-> Decision
    G2 -.-> AIDSS
    G3 -.-> AIDSS

    %% ── FOOTNOTE (in legend) ──
    subgraph Legend[" "]
        direction LR
        Note1["¹ Defineret i LOGGING_SPEC"]
        Note2["² Kan afledes fra eksisterende data"]
        Note3["³ Kræver logging-implementering"]
        LA["── Hovedflow"]
        LB["- - Constraint / støtte"]
    end

    %% ── STYLES ──
    style Inputs fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style AIDSS fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    style Decision fill:#fff3e0,stroke:#e65100,stroke-width:2px
    style Outcomes fill:#f3e5f5,stroke:#6a1b9a,stroke-width:2px
    style Governance fill:#f5f5f5,stroke:#9e9e9e,stroke-width:1px,stroke-dasharray: 5
    style Legend fill:#fafafa,stroke:#bdbdbd,stroke-dasharray: 3
