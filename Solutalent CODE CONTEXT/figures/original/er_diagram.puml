@startuml
title SoluTalent — ER-diagram (light, repo-deriveret)

entity "auth.users" as auth_users <<external>> {
  *id : uuid
}

entity "profiles" as profiles {
  *id : uuid
  user_id : uuid
  email : text
  role : app_role
}

entity "user_roles" as user_roles {
  *id : uuid
  user_id : uuid
  role : app_role
}

entity "user_sessions" as user_sessions {
  *id : uuid
  user_id : uuid
  login_at : timestamptz
}

entity "freelancers" as freelancers {
  *id : uuid
  name : text
  category : text
  seniority : text
}

entity "freelancer_skills" as freelancer_skills {
  *id : uuid
  freelancer_id : uuid
  skill : text
}

entity "hiring_specialists" as hiring_specialists {
  *id : uuid
  name : text
}

entity "jobs" as jobs {
  *id : uuid
  title : text
  hiring_specialist_id : uuid
}

entity "projects" as projects {
  *id : uuid
  project_title : text
  status : text
}

entity "project_skills" as project_skills {
  *id : uuid
  project_id : uuid
  skill_id : uuid
}

entity "skills" as skills {
  *id : uuid
  name : text
}

entity "bids" as bids {
  *id : uuid
  job_id : uuid
  freelancer_id : uuid
  status : text
}

entity "project_bids" as project_bids {
  *id : uuid
  project_id : uuid
  freelancer_id : uuid
  status : bid_status
  reviewed_by : uuid
}

entity "contracts" as contracts {
  *id : uuid
  project_id : uuid
  freelancer_id : uuid
  client_id : uuid
  status : text
}

entity "contract_versions" as contract_versions {
  *id : uuid
  contract_id : uuid
  created_by : uuid
}

entity "contract_signatures" as contract_signatures {
  *id : uuid
  contract_id : uuid
  signer_id : uuid
}

entity "time_entries" as time_entries {
  *id : uuid
  freelancer_id : uuid
  project_id : uuid
  hours : numeric
  status : text
}

entity "payment_accounts" as payment_accounts {
  *id : uuid
  freelancer_id : uuid
  account_type : text
}

entity "withdrawals" as withdrawals {
  *id : uuid
  freelancer_id : uuid
  payment_account_id : uuid
  amount : numeric
}

entity "economic_sync_log" as economic_sync_log {
  *id : uuid
  sync_type : text
  triggered_by_user_id : uuid
}

entity "match_requests" as match_requests {
  *id : uuid
  freelancer_id : uuid
  job_id : uuid
  reviewed_by : uuid
}

entity "match_results" as match_results {
  *id : uuid
  match_request_id : uuid
  overall_score : int
}

entity "job_embeddings" as job_embeddings {
  *id : uuid
  job_id : uuid
}

entity "freelancer_embeddings" as freelancer_embeddings {
  *id : uuid
  freelancer_id : uuid
}

profiles }o--|| auth_users : user_id
user_roles }o--|| auth_users : user_id
user_sessions }o--|| auth_users : user_id

freelancer_skills }o--|| freelancers : freelancer_id

jobs }o--|| hiring_specialists : hiring_specialist_id
bids }o--|| jobs : job_id
bids }o--|| freelancers : freelancer_id

project_skills }o--|| projects : project_id
project_skills }o--|| skills : skill_id

project_bids }o--|| projects : project_id
project_bids }o--|| freelancers : freelancer_id
project_bids }o--|| auth_users : reviewed_by

contracts }o--|| projects : project_id
contracts }o--|| freelancers : freelancer_id
contracts }o--|| auth_users : client_id

contract_versions }o--|| contracts : contract_id
contract_versions }o--|| auth_users : created_by
contract_signatures }o--|| contracts : contract_id
contract_signatures }o--|| auth_users : signer_id

time_entries }o--|| projects : project_id
time_entries }o--|| auth_users : freelancer_id

payment_accounts }o--|| freelancers : freelancer_id
withdrawals }o--|| freelancers : freelancer_id
withdrawals }o--|| payment_accounts : payment_account_id

economic_sync_log }o--|| auth_users : triggered_by_user_id

match_requests }o--|| freelancers : freelancer_id
match_requests }o--|| jobs : job_id
match_requests }o--|| auth_users : reviewed_by
match_results }o--|| match_requests : match_request_id

job_embeddings }o--|| jobs : job_id
freelancer_embeddings }o--|| freelancers : freelancer_id

@enduml

