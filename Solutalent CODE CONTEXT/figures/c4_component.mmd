%% F5 — C4 Component Diagram (Repo-afledt, light)
%% Viser: Logiske moduler i Frontend-lag og Edge Functions-lag
%% C4-niveau 3: Hvordan er koden organiseret internt?
flowchart TB
    %% ── FRONTEND LAYER ──
    subgraph Frontend["Frontend-lag  <i>(React SPA)</i>"]
        Pages["<b>Pages</b><br/><i>Route-komponenter</i>"]
        Components["<b>Components</b><br/><i>UI-byggeklodser</i>"]
        Hooks["<b>Hooks</b><br/><i>State · React Query</i>"]
        Services["<b>Services</b><br/><i>Forretningslogik</i>"]
        SBClient["<b>Supabase Client</b><br/><i>API-wrapper</i>"]

        Pages --> Components --> Hooks --> Services --> SBClient
    end

    %% ── EDGE FUNCTIONS LAYER ──
    subgraph EdgeLayer["Edge Functions-lag  <i>(Deno)</i>"]
        AI["<b>AI & Matching</b><br/><i>Match, embeddings,<br/>CV-parsing</i>"]
        Contracts["<b>Kontrakter</b><br/><i>Generering fra bud</i>"]
        EconEF["<b>E-conomic</b><br/><i>Faktura-sync</i>"]
        Comms["<b>Kommunikation</b><br/><i>E-mail, notifikationer</i>"]
    end

    %% ── DATABASE ──
    DB[("<b>PostgreSQL</b><br/><i>249 migrationer · 585 RLS-policies</i>")]

    %% ── EXTERNAL ──
    subgraph External["Eksterne services"]
        OpenAI["OpenAI API"]
        Economic["E-conomic API"]
        Resend["Resend"]
    end

    %% ── CONNECTIONS ──
    SBClient -->|"PostgREST"| DB
    SBClient -->|"RPC"| EdgeLayer

    AI --> OpenAI
    EconEF --> Economic
    Comms --> Resend

    AI -.-> DB
    Contracts -.-> DB
    EconEF -.-> DB

    %% ── LEGEND ──
    subgraph Legend[" "]
        direction LR
        LF["◻ Frontend-modul"]
        LE["◻ Edge Function-modul"]
        LD[("◻ Datastore")]
        LX["◻ Ekstern service"]
        LA["── Kald / afhængighed"]
        LB["- - Dataadgang"]
    end

    %% ── STYLES ──
    style Frontend fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    style EdgeLayer fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style DB fill:#fff3e0,stroke:#e65100,stroke-width:2px
    style External fill:#f5f5f5,stroke:#9e9e9e,stroke-width:1px,stroke-dasharray: 5
    style Legend fill:#fafafa,stroke:#bdbdbd,stroke-dasharray: 3
    style LF fill:#e8f5e9,stroke:#2e7d32
    style LE fill:#e3f2fd,stroke:#1565c0
    style LD fill:#fff3e0,stroke:#e65100
    style LX fill:#f5f5f5,stroke:#9e9e9e
